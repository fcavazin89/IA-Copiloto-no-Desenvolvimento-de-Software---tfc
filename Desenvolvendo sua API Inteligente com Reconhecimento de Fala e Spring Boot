package com.example.smartbudgetapi.ai;

import com.example.smartbudgetapi.model.Transaction;
import com.example.smartbudgetapi.service.TransactionService;
import org.slf4j.Logger;
import org.slf4j.LoggerFactory;
import org.springframework.ai.chat.client.ChatClient;
import org.springframework.ai.chat.messages.Message;
import org.springframework.ai.chat.messages.UserMessage;
import org.springframework.ai.chat.model.ChatModel;
import org.springframework.ai.chat.prompt.Prompt;
import org.springframework.ai.openai.OpenAiChatModel;
import org.springframework.ai.openai.api.OpenAiApi;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Component;

import java.math.BigDecimal;
import java.time.LocalDate;
import java.util.ArrayList;
import java.util.List;

@Component
public class BudgetTools {

    private static final Logger logger = LoggerFactory.getLogger(BudgetTools.class);

    @Autowired
    private TransactionService transactionService;

    @Autowired
    private ChatClient chatClient; // Injetado automaticamente pelo Spring AI starter

    // Tool para adicionar uma despesa
    public String addExpense(String description, double amount, String dateStr) {
        try {
            LocalDate date = dateStr != null ? LocalDate.parse(dateStr) : LocalDate.now();
            Transaction expense = new Transaction(description, BigDecimal.valueOf(amount), "EXPENSE", date);
            Transaction savedExpense = transactionService.save(expense);
            logger.info("Despesa adicionada: {}", savedExpense);
            return "Despesa de R$ " + amount + " para '" + description + "' adicionada com sucesso.";
        } catch (Exception e) {
            logger.error("Erro ao adicionar despesa: ", e);
            return "Erro ao adicionar despesa: " + e.getMessage();
        }
    }

    // Tool para adicionar uma receita
    public String addIncome(String description, double amount, String dateStr) {
        try {
            LocalDate date = dateStr != null ? LocalDate.parse(dateStr) : LocalDate.now();
            Transaction income = new Transaction(description, BigDecimal.valueOf(amount), "INCOME", date);
            Transaction savedIncome = transactionService.save(income);
            logger.info("Receita adicionada: {}", savedIncome);
            return "Receita de R$ " + amount + " para '" + description + "' adicionada com sucesso.";
        } catch (Exception e) {
            logger.error("Erro ao adicionar receita: ", e);
            return "Erro ao adicionar receita: " + e.getMessage();
        }
    }

    // Tool para obter o total de despesas
    public String getTotalExpenses() {
        try {
            BigDecimal total = transactionService.calculateTotalByType("EXPENSE");
            logger.info("Total de despesas solicitado: {}", total);
            return "O total de despesas é R$ " + total;
        } catch (Exception e) {
            logger.error("Erro ao calcular total de despesas: ", e);
            return "Erro ao calcular total de despesas: " + e.getMessage();
        }
    }

    // Tool para obter o total de receitas
    public String getTotalIncomes() {
        try {
            BigDecimal total = transactionService.calculateTotalByType("INCOME");
            logger.info("Total de receitas solicitado: {}", total);
            return "O total de receitas é R$ " + total;
        } catch (Exception e) {
            logger.error("Erro ao calcular total de receitas: ", e);
            return "Erro ao calcular total de receitas: " + e.getMessage();
        }
    }

    // Tool para obter todas as transações recentes (últimos 7 dias, por exemplo)
    public String getRecentTransactions() {
        try {
            LocalDate endDate = LocalDate.now();
            LocalDate startDate = endDate.minusDays(7);
            List<Transaction> transactions = transactionService.findByTransactionDateBetween(startDate, endDate);
            logger.info("Transações recentes solicitadas ({} a {}). Quantidade: {}", startDate, endDate, transactions.size());
            if (transactions.isEmpty()) {
                return "Nenhuma transação encontrada nos últimos 7 dias.";
            }
            StringBuilder sb = new StringBuilder("Transações recentes:\n");
            for (Transaction t : transactions) {
                sb.append("- ").append(t.getType()).append(": ").append(t.getDescription())
                  .append(" (R$ ").append(t.getAmount()).append(") em ").append(t.getTransactionDate()).append("\n");
            }
            return sb.toString();
        } catch (Exception e) {
            logger.error("Erro ao buscar transações recentes: ", e);
            return "Erro ao buscar transações recentes: " + e.getMessage();
        }
    }
}

