@RestController
@RequestMapping("/api/budget")
public class TransactionController {

    private static final Logger logger = LoggerFactory.getLogger(TransactionController.class);

    @Autowired
    private TransactionService transactionService;

    @Autowired
    private BudgetTools budgetTools;

    @Autowired
    private ChatClient chatClient; // Injetado automaticamente

    // Endpoint REST convencional para transações
    @GetMapping("/transactions")
    public ResponseEntity<List<Transaction>> getAllTransactions() {
        List<Transaction> transactions = transactionService.findAll();
        return ResponseEntity.ok(transactions);
    }

    @PostMapping("/transactions")
    public ResponseEntity<Transaction> createTransaction(@RequestBody Transaction transaction) {
        Transaction savedTransaction = transactionService.save(transaction);
        return ResponseEntity.ok(savedTransaction);
    }

    // Endpoint para processar áudio de voz -> texto -> IA -> áudio de resposta
    @PostMapping(value = "/voice", consumes = MediaType.MULTIPART_FORM_DATA_VALUE)
    public ResponseEntity<byte[]> processVoiceCommand(
            @RequestParam("audio") MultipartFile audioFile,
            @RequestParam(value = "userId", required = false) String userId) { // Exemplo de contexto

        logger.info("Recebido arquivo de áudio para processamento: {}", audioFile.getOriginalFilename());

        try {
            // 1. Transcrever áudio para texto (simulado ou via API real)
            // Para este exemplo, vamos simular a transcrição
            String audioContent = new String(audioFile.getBytes()); // Isso NÃO é uma transcrição real!
            String transcription = simulateTranscription(audioContent); // Substitua por chamada real à API de transcrição

            logger.info("Texto transcrito: {}", transcription);

            // 2. Preparar contexto e mensagem para o ChatClient
            String systemPrompt = """
                Você é um assistente financeiro inteligente. Interprete os comandos do usuário e utilize as ferramentas disponíveis para gerenciar o orçamento.
                As ferramentas disponíveis são:
                 - addExpense(description, amount, date): Adiciona uma despesa.
                 - addIncome(description, amount, date): Adiciona uma receita.
                 - getTotalExpenses(): Retorna o total de despesas.
                 - getTotalIncomes(): Retorna o total de receitas.
                 - getRecentTransactions(): Retorna transações recentes.
                Use o formato correto para chamar as ferramentas.
                Responda em português brasileiro de forma clara e concisa.
                """;

            Map<String, Object> context = new HashMap<>();
            context.put("userId", userId != null ? userId : "default_user"); // Exemplo de contexto
            // Adicione outras informações contextuais se necessário

            // 3. Chamar o ChatClient com Tool Calling habilitado
            String responseText = chatClient
                    .prompt()
                    .user(transcription)
                    .system(systemPrompt)
                    .context(context)
                    .call()
                    .content(); // O conteúdo da resposta final após Tool Calls


            logger.info("Resposta gerada pela IA: {}", responseText);

            // 4. Converter texto de resposta para áudio (simulado ou via API real)
            // Para este exemplo, vamos simular a geração de áudio
            byte[] audioResponse = simulateAudioGeneration(responseText); // Substitua por chamada real à API de síntese de voz

            // 5. Retornar o áudio como resposta
            HttpHeaders headers = new HttpHeaders();
            headers.setContentType(MediaType.parseMediaType("audio/wav")); // Ou mp3, ogg, etc.
            headers.setContentLength(audioResponse.length);
            headers.set(HttpHeaders.CONTENT_DISPOSITION, "inline; filename=response.wav");

            return ResponseEntity.ok().headers(headers).body(audioResponse);

        } catch (Exception e) {
            logger.error("Erro ao processar comando de voz: ", e);
            return ResponseEntity.internalServerError().build();
        }
    }

    // Simulação de transcrição. Substitua por uma chamada real à API (ex: OpenAI Audio API).
