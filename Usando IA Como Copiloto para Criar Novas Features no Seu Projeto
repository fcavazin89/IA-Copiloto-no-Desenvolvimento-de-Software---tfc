def calcular_mediana(lista_numeros):
    """
    Calcula e retorna a mediana de uma lista de números.
    A mediana é o valor que divide a lista ordenada ao meio.
    Se a lista tiver um número par de elementos, a mediana é a
    média dos dois valores centrais.
    :param lista_numeros: Lista de números (int ou float)
    :return: Mediana (float)
    """
    if not lista_numeros:
        raise ValueError("A lista não pode estar vazia.")
    lista_ordenada = sorted(lista_numeros)
    n = len(lista_ordenada)
    meio = n // 2
    if n % 2 == 0:
        return (lista_ordenada[meio - 1] + lista_ordenada[meio]) / 2
    else:
        return lista_ordenada[meio]

